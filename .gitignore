# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — JANGAN pernah commit secrets!
.env*
!.env.local.example

# vercel
.vercel

# typescript build artifacts
*.tsbuildinfo
next-env.d.ts

# supabase temp
/supabase/.temp/

