*.tmp.js
*.tmp.ts
tmp_*.js
tmp_*.ts
check_*.js
check_*.ts
get_*.js
get_*.ts
debug_*.js
audit_*.js
scan_*.js
search_*.js
trace_*.js
find_*.js
verify_*.ts
fix_*.js
.claude/settings.local.json

# Sentry Config File
.env.sentry-build-plugin
scratch/db-backups/
.next
.backups/
docs/node_modules/*
