# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
# /.next/ — commented out, we commit .next build output from CI
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — JANGAN pernah commit secrets!
.env*
!.env.local.example

# vercel
.vercel

# typescript build artifacts
*.tsbuildinfo
next-env.d.ts

# supabase temp
/supabase/.temp/

# one-off debug/audit scripts (jangan commit file ini)
*.tmp.js
*.tmp.ts
tmp_*.js
tmp_*.ts
check_*.js
check_*.ts
get_*.js
get_*.ts
debug_*.js
audit_*.js
scan_*.js
search_*.js
trace_*.js
find_*.js
verify_*.ts
fix_*.js
# scratch scripts di ROOT (bukan di /scripts, /tests)
/test-*.mjs
/test-*.ts
/test-*.js
/test_*.mjs
/test_*.ts
/test_*.js
/fix-*.mjs
/fix-*.ts
/reload_*.mjs
/reload-*.mjs
/set-*.mjs
/update_*.mjs
/update-*.mjs
.claude/settings.local.json

# Sentry Config File
.env.sentry-build-plugin
scratch/db-backups/

# Python scratch files (root only)
/*.py

# Router proxy scratch files
__pycache__/
*.pyc
/ROUTER_PROXY_SETUP.md
/run_router_proxy.sh
/setup_router_proxy.sh
