# ══════════════════════════════════════════════════════════════
# NIZAM ERP — Environment Variables
# ══════════════════════════════════════════════════════════════
# Salin file ini menjadi .env.local lalu isi sesuai kebutuhan.
#
# ⚠️ PENTING: Project ini SUDAH 100% pakai Railway PostgreSQL.
# TIDAK ADA koneksi ke Supabase Cloud.
#
# Variabel SUPABASE_* di file ini hanya untuk LEGACY tooling
# (migration scripts archived di scripts/legacy/).
# Untuk runtime production: cukup isi DATABASE_URL ke Railway.
#
# JANGAN pernah commit .env.local ke Git!
# ══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# DATABASE (REQUIRED) — Railway PostgreSQL
# ──────────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway
RAILWAY_DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway
DATABASE_PUBLIC_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# ──────────────────────────────────────────────────────────────
# AUTH (REQUIRED) — Internal Auth Nizam-native
# ──────────────────────────────────────────────────────────────
# Mode satu-satunya yang didukung di production
AUTH_PROVIDER=internal
NEXT_PUBLIC_AUTH_PROVIDER=internal
NEXTAUTH_SECRET=replace-with-random-long-secret-string
INTERNAL_AUTH_SESSION_SECRET=replace-with-random-long-secret

# Optional untuk script bootstrap akun internal:
# INTERNAL_AUTH_BOOTSTRAP_PASSWORD=temporary-password

# Disable Supabase password fallback (sudah TIDAK didukung)
INTERNAL_AUTH_SUPABASE_PASSWORD_FALLBACK=false

# ──────────────────────────────────────────────────────────────
# STORAGE (REQUIRED) — Railway S3-compatible bucket
# ──────────────────────────────────────────────────────────────
RAILWAY_STORAGE_ENDPOINT=https://t3.storageapi.dev
RAILWAY_STORAGE_REGION=auto
RAILWAY_STORAGE_BUCKET=your-bucket-name
RAILWAY_STORAGE_ACCESS_KEY_ID=tid_xxxxxxxxxxxxxxxxxx
RAILWAY_STORAGE_SECRET_ACCESS_KEY=tsec_xxxxxxxxxxxxxxxxxx
RAILWAY_STORAGE_FORCE_PATH_STYLE=true
RAILWAY_STORAGE_SIGNED_URL_TTL_SECONDS=3600
RAILWAY_STORAGE_ENABLE_LOGO_UPLOADS=true
RAILWAY_STORAGE_ENABLE_EXPORTS=true

# ──────────────────────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────────────────────
# Base URL aplikasi publik (fallback saat host request tidak tersedia)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────
# AI / GOOGLE CLOUD (Optional)
# ──────────────────────────────────────────────────────────────
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_AI_STUDIO_KEY=your-google-ai-studio-key

# ──────────────────────────────────────────────────────────────
# EMAIL (Optional) — Mailketing untuk invoice/promo/reset password
# ──────────────────────────────────────────────────────────────
# MAILKETING_API_TOKEN=your-mailketing-token
# MAILKETING_FROM_EMAIL=info@kliknizam.app

# ──────────────────────────────────────────────────────────────
# SCHEDULED REPORTS (Optional)
# ──────────────────────────────────────────────────────────────
# WEEKLY_SYSTEM_USAGE_REPORT_RECIPIENTS=admin@example.com
# WEEKLY_SYSTEM_USAGE_REPORT_SECRET=replace-with-random-long-secret
# WEEKLY_SYSTEM_USAGE_REPORT_DAY=1
# WEEKLY_SYSTEM_USAGE_REPORT_TIME=07:00
# WEEKLY_SYSTEM_USAGE_REPORT_TIMEZONE=Asia/Jakarta
# SCHEDULER_SECRET=replace-with-random-long-secret

# ──────────────────────────────────────────────────────────────
# DATABASE BACKUP SCHEDULER (Optional but Recommended)
# ──────────────────────────────────────────────────────────────
BACKUP_SCHEDULER_ENABLED=true
BACKUP_SCHEDULER_TIMEZONE=Asia/Jakarta
BACKUP_SCHEDULER_CRON=0 3 * * *
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_USER_ID=your-telegram-user-id

# ──────────────────────────────────────────────────────────────
# MAGNIFIC AI (Optional) — Image generation untuk ekspresi Telegram
# ──────────────────────────────────────────────────────────────
# MAGNIFIC_API_KEY=FPSX_your_key
# MAGNIFIC_DAILY_LIMIT=20

# ──────────────────────────────────────────────────────────────
# MONITORING (Optional) — Sentry
# ──────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://<public-key>@o<org>.ingest.sentry.io/<project-id>
# SENTRY_DSN=https://<public-key>@o<org>.ingest.sentry.io/<project-id>
# SENTRY_ENABLED=true
# SENTRY_ENVIRONMENT=development
# SENTRY_AUTH_TOKEN=sntrys_<token>
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_RELEASE=git-sha-or-app-version

# ──────────────────────────────────────────────────────────────
# ANALYTICS (Optional) — Microsoft Clarity
# ──────────────────────────────────────────────────────────────
# NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-id

# ══════════════════════════════════════════════════════════════
# LEGACY — Supabase Compatibility (TIDAK DIPAKAI di production)
# ══════════════════════════════════════════════════════════════
# Variables di bawah ini sudah TIDAK aktif. Disimpan hanya untuk
# compatibility dengan beberapa legacy tooling/migration scripts.
# Migrasi sudah selesai — semua data ada di Railway.
#
# Kalau lu developer baru: ABAIKAN block ini.
# ══════════════════════════════════════════════════════════════

# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ──────────────────────────────────────────────────────────────
# CARA SETUP CEPAT
# ──────────────────────────────────────────────────────────────
# 1. Copy file ini: cp .env.local.example .env.local
# 2. Isi DATABASE_URL ke Railway PostgreSQL
# 3. Isi NEXTAUTH_SECRET dengan random string panjang
# 4. Isi RAILWAY_STORAGE_* untuk upload file
# 5. npm install
# 6. npm run dev
# ──────────────────────────────────────────────────────────────
